generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Categoria {
  EXPOSITOR
  CAFEICULTOR
  VISITANTE
  IMPRENSA
  COMISSAO_ORGANIZADORA
  COLABORADOR_TERCEIRIZADO
}

enum StatusCredenciamento {
  CADASTRADO
  APROVADO
  BLOQUEADO
  CHECKED_IN
}

enum StatusCredencial {
  GERADA
  ATIVA
  INATIVA
  UTILIZADA
}

enum TipoEventoSistema {
  CREDENCIAMENTO_CRIADO
  CREDENCIAL_GERADA
  DADOS_ATUALIZADOS
  ACESSO_VALIDADO
  ACESSO_NEGADO
}

enum AdminRole {
  ADMIN
  APP_GATE
  SYSTEM
}

enum AccessResult {
  ALLOW
  DENY
}

enum AccessReason {
  CREDENCIAL_INVALIDA
  CREDENCIAL_BLOQUEADA
  JA_UTILIZADA
  FORA_DO_HORARIO
  ACESSO_PERMITIDO
}

enum AuditActorType {
  ADMIN_USER
  APP_GATE
  SYSTEM
}

model Credenciado {
  id                   String               @id @default(uuid()) @db.Uuid
  categoria            Categoria
  statusCredenciamento StatusCredenciamento @default(CADASTRADO)
  nomeCompleto         String
  cpf                  String               @unique
  rg                   String
  celular              String
  email                String               @unique
  municipio            String
  uf                   String
  aceitouLgpd          Boolean

  cnpj            String?
  siteEmpresa     String?
  nomeEmpresa     String?
  ccir            String?
  nomePropriedade String?
  nomeVeiculo     String?
  funcaoCargo     String?

  credencial Credencial?
  eventos    EventoSistema[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria, statusCredenciamento])
}

model Credencial {
  id              String           @id @default(uuid()) @db.Uuid
  credenciadoId   String           @unique @db.Uuid
  codigoUnico     String           @unique
  qrCodePayload   String
  statusCredencial StatusCredencial @default(GERADA)
  emitidaEm       DateTime

  credenciado Credenciado @relation(fields: [credenciadoId], references: [id], onDelete: Cascade)
  accessAttempts AccessAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventoSistema {
  id            String           @id @default(uuid()) @db.Uuid
  credenciadoId String?          @db.Uuid
  tipoEvento    TipoEventoSistema
  descricao     String
  metadata      Json?
  createdAt     DateTime         @default(now())

  credenciado Credenciado? @relation(fields: [credenciadoId], references: [id], onDelete: SetNull)

  @@index([credenciadoId])
  @@index([tipoEvento])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  nome         String
  role         AdminRole @default(ADMIN)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
}

model AuditLog {
  id         String         @id @default(uuid()) @db.Uuid
  actorType  AuditActorType
  actorId    String?        @db.Uuid
  acao       String
  recurso    String
  recursoId  String?
  detalhes   Json?
  createdAt  DateTime       @default(now())

  actor AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorType, createdAt])
  @@index([recurso, recursoId])
}

model GateDevice {
  id          String   @id @default(uuid()) @db.Uuid
  codigo      String   @unique
  nome        String
  localizacao String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accessAttempts AccessAttempt[]
}

model AccessAttempt {
  id           String       @id @default(uuid()) @db.Uuid
  credencialId String?      @db.Uuid
  gateDeviceId String?      @db.Uuid
  accessPoint  String?
  resultado    AccessResult
  motivo       AccessReason
  metadata     Json?
  createdAt    DateTime     @default(now())

  credencial Credencial? @relation(fields: [credencialId], references: [id], onDelete: SetNull)
  gateDevice GateDevice? @relation(fields: [gateDeviceId], references: [id], onDelete: SetNull)

  @@index([credencialId, createdAt])
  @@index([resultado, motivo, createdAt])
}
